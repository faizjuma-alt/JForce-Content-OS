{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && next build",
  "framework": "nextjs",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/upload/route.ts": { "maxDuration": 60 },
    "src/app/api/campaigns/[id]/push/route.ts": { "maxDuration": 30 },
    "src/app/api/webhook/route.ts": { "maxDuration": 30 }
  }
}
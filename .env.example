# ─── Database ────────────────────────────────────────────────
# Vercel Postgres or Neon: copy the pooled connection string here.
DATABASE_URL="postgres://user:pass@host/db?sslmode=require"

# ─── Auth (NextAuth v5) ──────────────────────────────────────
# Generate a 32-byte secret:  openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
# Production: your app's URL. Local dev leave blank.
AUTH_URL="https://jforce.yourdomain.com"
# Trust the Vercel host header
AUTH_TRUST_HOST="true"

# ─── Magic-link email (Resend, SendGrid, or any SMTP) ────────
EMAIL_SERVER_HOST="smtp.resend.com"
EMAIL_SERVER_PORT="465"
EMAIL_SERVER_USER="resend"
EMAIL_SERVER_PASSWORD="re_xxxxxxxx"
EMAIL_FROM="JForce Engine <noreply@yourdomain.com>"

# ─── Allowlist (only these emails can sign in) ──────────────
# Comma-separated. Anyone not on this list is rejected at sign-in.
ALLOWED_EMAILS="faiz.juma@jumia.com"

# ─── File storage ────────────────────────────────────────────
# Pick ONE of the two providers below. App auto-detects.
#
# Option A — Supabase (recommended; same provider as Postgres):
SUPABASE_URL="https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."
SUPABASE_BUCKET="jforce-knowledge"
#
# Option B — Vercel Blob (skip the SUPABASE_* vars above and set this):
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# ─── Upstash Redis (rate limiting) ───────────────────────────
# From upstash.com → Create Redis → REST credentials.
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxxxxxxxx"

# ─── Workflow integration ────────────────────────────────────
# Where Push to Workflow sends payloads.
CODEWORDS_WEBHOOK_URL=""
# Used to verify inbound webhook callbacks from CodeWords/n8n.
WEBHOOK_HMAC_SECRET="replace-with-openssl-rand-hex-32"

# ─── Publish-only (NotebookLM Video Overviews → YouTube) ─────
# The CodeWords /publish_only endpoint that uploads an already-rendered video
# to YouTube (skips HeyGen). Used by /api/campaigns/:id/publish.
CODEWORDS_PUBLISH_URL="https://runtime.codewords.ai/run/jforce_content_pipeline_09bce64d/publish_only"
# CodeWords API key (starts with cwk-). Server-only — never exposed to the browser.
CODEWORDS_API_KEY=""

# ─── Optional: pre-seed shared secrets used by the workflow ──
CLAUDE_API_KEY=""
HEYGEN_API_KEY=""
HEYGEN_AVATAR_ID=""
HEYGEN_VOICE_EN=""
HEYGEN_VOICE_FR=""
HEYGEN_VOICE_AR=""
